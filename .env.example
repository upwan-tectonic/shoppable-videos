# ─────────────────────────────────────────────────────────────────────────────
# Environment variables for the Shoppable Videos app.
#
# For LOCAL DEVELOPMENT you normally do NOT need to create a .env file:
# `shopify app dev` injects these automatically from your linked app + tunnel.
# This file documents the variables for reference and for production/self-hosting
# (`npm run build && npm start`), where you must supply them yourself.
# ─────────────────────────────────────────────────────────────────────────────

# From your app in the Shopify Partners dashboard (Overview → Client credentials).
SHOPIFY_API_KEY=your_client_id
SHOPIFY_API_SECRET=your_client_secret

# Comma-separated OAuth scopes. Must match shopify.app.toml [access_scopes].
SCOPES=read_products,write_metaobjects

# Public HTTPS URL where the app is hosted (the tunnel URL in dev, your domain in prod).
SHOPIFY_APP_URL=https://your-app-url.example.com

# Optional: only set when developing against a store on a custom domain.
# SHOP_CUSTOM_DOMAIN=your-store.example.com
